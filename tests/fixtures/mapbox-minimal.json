{
  "version": 8,
  "name": "Mapbox Streets",
  "metadata": { "mapbox:autocomposite": true },
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    }
  },
  "sprite": "mapbox://sprites/mapbox/streets-v12",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "fog": { "range": [1, 10] },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f8f4f0" }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "paint": { "fill-color": "#d2edae" }
    },
    {
      "id": "road-simple",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": 2
      }
    },
    {
      "id": "place-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "layout": {
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-field": "{name}",
        "text-size": 14
      },
      "paint": {
        "text-color": "#333333"
      }
    }
  ],
  "owner": "mapbox",
  "visibility": "public",
  "draft": false
}
